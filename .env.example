# ChainGuard (.env.example)
# This repo uses per-service .env files. Copy the relevant section into:
# - backend/.env
# - frontend/.env.local
# - ai-engine/.env (optional)

## backend/.env
# AUTH_REQUIRED=false
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# GEMINI_API_KEY=
# OPEN_ROUTE_SERVICE_KEY=
# OPEN_WEATHER_KEY=
# SEED_SHIPMENTS=true
# ALWAYS_COMPUTE_ROUTES=true

## frontend/.env.local (local dev)
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000
# NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:5000
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # optional; only if you implement web push


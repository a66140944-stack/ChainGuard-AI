# ============================
# Root Environment files
# ============================
.env
backend/.env
ai-engine/.env
/.venv
/env/
/venv/
/ENV/
/env.bak/
/venv.bak/
.env.local
.env.*.local

# Node and Next.js artifacts
node_modules/
.next/

# ============================
# Python standard ignores
# ============================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================
# Jupyter & OS Files
# ============================
.ipynb_checkpoints
.DS_Store
Thumbs.db

# ============================
# AI Engine
# ============================

# Ignore massive CSV datasets
ai-engine/dataset/*.csv

# Keep generator scripts explicitly tracked
!ai-engine/dataset/generate_dataset.py
!ai-engine/dataset/preprocess_dataco.py
!ai-engine/dataset/preprocess_faf.py
!ai-engine/dataset/fetch_uci_online_retail.py

# NOTE: ML model artifacts are ignored by default.
# Teammates should run `python train.py` to generate model files locally.
ai-engine/models/

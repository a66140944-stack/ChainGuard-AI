# ChainGuard backend environment example
# Copy this file to backend/.env and replace placeholders with real values.

SECRET_KEY=replace_with_a_long_random_secret
JWT_SECRET_KEY=replace_with_a_long_random_jwt_secret
JWT_ISSUER=chainguard-backend
AUTH_REQUIRED=false
PORT=5000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Persistence priority:
# 1. Google Cloud Storage
# 2. MongoDB / MongoDB Atlas
# 3. Memory-only fallback
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/chainguard?retryWrites=true&w=majority&appName=Cluster0

# External APIs
OPENWEATHER_API_KEY=
OPEN_ROUTE_SERVICE_KEY=
GOOGLE_MAPS_KEY=
GEMINI_API_KEY=

# MQTT ingestion
MQTT_ENABLED=false
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_TOPIC=chainguard/shipments/#
MQTT_CLIENT_ID=chainguard-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
